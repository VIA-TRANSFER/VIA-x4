<ui:FluentWindow x:Class="Via.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="VIA x4"
        Width="600" Height="660"
        MinWidth="520" MinHeight="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        AllowDrop="True"
        Drop="OnFileDrop"
        DragOver="OnDragOver"
        PreviewKeyDown="Window_PreviewKeyDown">

    <ui:FluentWindow.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskbarInfo"/>
    </ui:FluentWindow.TaskbarItemInfo>

    <ui:FluentWindow.Resources>
        <Storyboard x:Key="DropIconPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="dropIconScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.08" Duration="0:0:1.5"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="dropIconScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.08" Duration="0:0:1.5"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="BorderRotateAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="dropBorderRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:3">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- Fluent 2 subtle card elevation (Shadow2) -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="6" ShadowDepth="1" Direction="270"
                          Color="#000000" Opacity="0.08" RenderingBias="Performance"/>
        <!-- Fluent 2 shadow8 for card hover elevation -->
        <DropShadowEffect x:Key="CardShadowHover" BlurRadius="12" ShadowDepth="2" Direction="270"
                          Color="#000000" Opacity="0.12" RenderingBias="Performance"/>
        <!-- Fluent 2 shadow64 for overlay panels -->
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="32" ShadowDepth="8" Direction="270"
                          Color="#000000" Opacity="0.14" RenderingBias="Performance"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Native Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="" ShowMinimize="True" ShowMaximize="True" ShowClose="True">
            <ui:TitleBar.Header>
                <Image Source="/via_logo.png" Height="28" Margin="8,0,0,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- InfoBar -->
        <ui:InfoBar x:Name="infoBar" Grid.Row="1" IsOpen="False" IsClosable="True" Margin="8,0,8,0"/>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="24,8,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Subtitle -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:SymbolIcon Symbol="LockClosed24" FontSize="14"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="End-to-end encrypted file transfer"
                               Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                               FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="settingsBtn" VerticalAlignment="Center"
                               Appearance="Secondary" Padding="8,4" Click="Settings_Click"
                               ToolTip="Settings" Margin="0,0,4,0"
                               AutomationProperties.Name="Settings">
                        <ui:SymbolIcon x:Name="settingsIcon" Symbol="Settings24" FontSize="16"/>
                    </ui:Button>
                    <ui:Button x:Name="historyBtn" VerticalAlignment="Center"
                               Appearance="Secondary" Padding="8,4" Click="History_Click"
                               ToolTip="Transfer history"
                               AutomationProperties.Name="Transfer history">
                        <ui:SymbolIcon x:Name="historyIcon" Symbol="History24" FontSize="16"/>
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!-- Pill Toggle -->
            <Border Grid.Row="1" Margin="0,0,0,20" CornerRadius="16" Height="32"
                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" x:Name="pillContainer" Padding="4">
                <Grid x:Name="pillGrid" SizeChanged="PillGrid_SizeChanged">
                    <Border x:Name="pillHighlight" CornerRadius="12" HorizontalAlignment="Left"
                            Background="{ui:ThemeResource SystemAccentColorPrimaryBrush}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="pillTranslate" X="0"/>
                        </Border.RenderTransform>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="Transparent" Cursor="Hand"
                                CornerRadius="12"
                                MouseLeftButtonDown="SendTab_Click"
                                MouseEnter="PillTab_MouseEnter" MouseLeave="PillTab_MouseLeave"
                                Focusable="True" KeyDown="SendTab_KeyDown"
                                AutomationProperties.Name="Send tab"
                                ToolTip="Send files or text">
                            <TextBlock x:Name="sendTabText" Text="Send" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>
                        <Border Grid.Column="1" Background="Transparent" Cursor="Hand"
                                CornerRadius="12"
                                MouseLeftButtonDown="RecvTab_Click"
                                MouseEnter="PillTab_MouseEnter" MouseLeave="PillTab_MouseLeave"
                                Focusable="True" KeyDown="RecvTab_KeyDown"
                                AutomationProperties.Name="Receive tab"
                                ToolTip="Receive files or text">
                            <TextBlock x:Name="recvTabText" Text="Receive" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>

            <!-- Send Panel -->
            <Grid x:Name="sendPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- File / Text mode toggle -->
                <Border Grid.Row="0" Margin="0,0,0,12" CornerRadius="12" Height="24"
                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" HorizontalAlignment="Left" Padding="3">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="fileModeBtn" CornerRadius="8" Padding="12,0" Cursor="Hand"
                                Background="{ui:ThemeResource SystemAccentColorPrimaryBrush}"
                                MouseLeftButtonDown="FileMode_Click"
                                MouseEnter="ModeBtn_MouseEnter" MouseLeave="ModeBtn_MouseLeave"
                                Focusable="True" KeyDown="FileMode_KeyDown"
                                AutomationProperties.Name="File mode"
                                ToolTip="Send files">
                            <TextBlock x:Name="fileModeText" Text="File" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>
                        <Border x:Name="textModeBtn" CornerRadius="8" Padding="12,0" Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonDown="TextMode_Click"
                                MouseEnter="ModeBtn_MouseEnter" MouseLeave="ModeBtn_MouseLeave"
                                Focusable="True" KeyDown="TextMode_KeyDown"
                                AutomationProperties.Name="Text mode"
                                ToolTip="Send text">
                            <TextBlock x:Name="textModeText" Text="Text" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Direct Transfer toggle chip — sits right-aligned in the same Row 0 as the File/Text toggle -->
                <Border x:Name="directModeChip" Grid.Row="0" HorizontalAlignment="Right"
                        VerticalAlignment="Center" CornerRadius="12" Height="24"
                        Background="Transparent"
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" Padding="8,0" Cursor="Hand"
                        MouseLeftButtonDown="DirectMode_Click"
                        MouseEnter="DirectChip_MouseEnter" MouseLeave="DirectChip_MouseLeave"
                        Focusable="True" KeyDown="DirectMode_KeyDown"
                        Margin="0,0,0,12"
                        AutomationProperties.Name="Direct Transfer mode toggle">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon x:Name="directModeIcon" Symbol="Globe24" FontSize="12"
                                       Margin="0,0,4,0"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="directModeText" Text="Direct Transfer" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ui:SymbolIcon x:Name="directInfoIcon" Symbol="Info16" FontSize="10"
                                       Margin="8,0,0,0" Cursor="Help"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       ToolTipService.InitialShowDelay="0">
                            <ui:SymbolIcon.ToolTip>
                                <ToolTip MaxWidth="260">
                                    <StackPanel>
                                        <TextBlock Text="Direct Transfer" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                   Text="Files go straight from your device to the receiver — no server in between. Faster on the same network, more private over the internet."/>
                                    </StackPanel>
                                </ToolTip>
                            </ui:SymbolIcon.ToolTip>
                        </ui:SymbolIcon>
                    </StackPanel>
                </Border>

                <!-- Unfinished transfer banner (shown on startup if a previous send was interrupted) -->
                <Border x:Name="resumeBanner" Grid.Row="1" Visibility="Collapsed"
                        CornerRadius="8" Padding="12" Margin="0,0,0,12"
                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource SystemAccentColorPrimaryBrush}"
                        BorderThickness="1" Effect="{StaticResource CardShadow}"
                        MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="resumeBannerTitle" Text="Unfinished transfer"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="resumeBannerDetail" Text=""
                                       FontSize="12" Margin="0,4,0,8"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Appearance="Primary" Padding="12,4"
                                           Click="ResumeBanner_Resume_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Resume" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </ui:Button>
                                <ui:Button Padding="12,4" Margin="8,0,0,0"
                                           Click="ResumeBanner_Dismiss_Click"
                                           Content="Dismiss" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                        <ui:SymbolIcon Grid.Column="1" Symbol="ArrowUpload24" FontSize="24"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Drop Zone (empty state) -->
                <Border Grid.Row="2" x:Name="dropZone"
                        BorderThickness="0" CornerRadius="8"
                        Background="Transparent"
                        MinHeight="120" Cursor="Hand"
                        Focusable="True" KeyDown="DropZone_KeyDown"
                        MouseLeftButtonUp="BrowseFile_Click"
                        MouseEnter="DropZone_MouseEnter"
                        MouseLeave="DropZone_MouseLeave"
                        DragEnter="DropZone_DragEnter"
                        DragLeave="DropZone_DragLeave"
                        AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver"
                        ToolTip="Drop a file or folder here, or click to browse"
                        AutomationProperties.Name="Drop zone - click to browse files">
                    <!-- Animated gradient border overlay -->
                    <Grid>
                        <Border x:Name="dropZoneBorder" CornerRadius="8"
                                BorderThickness="2" IsHitTestVisible="False">
                            <Border.BorderBrush>
                                <LinearGradientBrush x:Name="dropBorderBrush" StartPoint="0,0" EndPoint="1,1">
                                    <LinearGradientBrush.RelativeTransform>
                                        <RotateTransform x:Name="dropBorderRotate" CenterX="0.5" CenterY="0.5" Angle="0"/>
                                    </LinearGradientBrush.RelativeTransform>
                                    <GradientStop x:Name="dropGradStop0" Color="#40808080" Offset="0"/>
                                    <GradientStop x:Name="dropGradStop1" Color="#15808080" Offset="0.5"/>
                                    <GradientStop x:Name="dropGradStop2" Color="#40808080" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                        </Border>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon x:Name="dropIcon" Symbol="ArrowUpload24" FontSize="32"
                                          Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                          HorizontalAlignment="Center" Margin="0,0,0,8"
                                          RenderTransformOrigin="0.5,0.5">
                                <ui:SymbolIcon.RenderTransform>
                                    <ScaleTransform x:Name="dropIconScale" ScaleX="1" ScaleY="1"/>
                                </ui:SymbolIcon.RenderTransform>
                            </ui:SymbolIcon>
                            <TextBlock x:Name="dropLine1" Text="Drop files or folders here, or click to browse"
                                       HorizontalAlignment="Center"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0" FontSize="12">
                                <Hyperlink Click="BrowseSendFolder_Click"
                                           Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}">
                                    Browse folder
                                </Hyperlink>
                                <Run Text=" · Ctrl+O for files" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- File Preview Card (shown after file selected) -->
                <Border Grid.Row="2" x:Name="filePreviewCard" Visibility="Collapsed"
                        CornerRadius="8" Padding="16"
                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" Effect="{StaticResource CardShadow}"
                        AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver"
                        DragEnter="PreviewCard_DragEnter" DragLeave="PreviewCard_DragLeave"
                        MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- File Icon -->
                        <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                            <ui:SymbolIcon x:Name="sendFileSymbol" Symbol="Document24" FontSize="28"
                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                            <Image x:Name="sendFileIcon" Width="40" Height="40"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                        <!-- File Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="sendFileName" Text="" FontSize="14" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="sendFileDetail" Text="" FontSize="12" Margin="0,4,0,0"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                        <!-- Clear Button -->
                        <ui:Button x:Name="clearFileBtn" Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Padding="8,4" Click="ClearFile_Click"
                                   Appearance="Secondary" ToolTip="Remove file"
                                   AutomationProperties.Name="Remove selected file">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Text Input (text mode) -->
                <ui:TextBox x:Name="sendTextBox" Grid.Row="2" Visibility="Collapsed"
                            PlaceholderText="Type or paste text to send... (Ctrl+Enter to send)"
                            AutomationProperties.Name="Text to send"
                            AcceptsReturn="True" TextWrapping="Wrap"
                            MinHeight="120" MaxHeight="200"
                            VerticalScrollBarVisibility="Auto"
                            TextChanged="SendTextBox_TextChanged"/>

                <!-- Code Display -->
                <Border x:Name="codeCard" Grid.Row="3" Margin="0,12,0,0" Visibility="Collapsed"
                        CornerRadius="8" Padding="16,12"
                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock x:Name="codeCardLabel" Text="Share this code with the receiver"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="codeText" Grid.Column="0"
                                     Text="" FontSize="20" FontWeight="SemiBold"
                                     IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" Padding="0"
                                     Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                     VerticalAlignment="Center"
                                     IsTabStop="False"
                                     TextWrapping="NoWrap"/>
                            <ui:Button x:Name="copyBtn" Grid.Column="1"
                                       Appearance="Primary" Click="CopyCode_Click"
                                       Margin="12,0,0,0"
                                       ToolTip="Copy transfer code to clipboard"
                                       AutomationProperties.Name="Copy transfer code">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon x:Name="copyIcon" Symbol="Copy24" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="copyText" Text="Copy" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                        <!-- Direct P2P System Check (collapsible) -->
                        <StackPanel x:Name="directP2pStatusToggle" Orientation="Horizontal" Visibility="Collapsed"
                                    Cursor="Hand" Margin="0,8,0,0"
                                    MouseLeftButtonDown="DirectP2pStatusToggle_Click"
                                    MouseEnter="DisclosureToggle_MouseEnter" MouseLeave="DisclosureToggle_MouseLeave">
                            <ui:SymbolIcon x:Name="directP2pChevron" Symbol="ChevronRight24" FontSize="12"
                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,4,0" RenderTransformOrigin="0.5,0.5">
                                <ui:SymbolIcon.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </ui:SymbolIcon.RenderTransform>
                            </ui:SymbolIcon>
                            <TextBlock Text="System check" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Border x:Name="directP2pStatusCard" Margin="0,4,0,0" Visibility="Collapsed"
                                CornerRadius="6" Padding="12,8"
                                Background="{ui:ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock x:Name="directP2pChecklist" Text="" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                       LineHeight="18" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Progress -->
                <StackPanel Grid.Row="4" Margin="0,12,0,0" x:Name="sendProgressPanel" Visibility="Collapsed">
                    <ProgressBar x:Name="sendProgress" IsIndeterminate="True" Minimum="0" Maximum="100"/>
                    <Grid Margin="0,4,0,0">
                        <TextBlock x:Name="sendProgressDetail" Text="" FontSize="12"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="sendElapsedText" Text="" FontSize="12"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid x:Name="sendSpeedRow" Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="sendSpeedText" Text="" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="sendEtaText" Text="" FontSize="12"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Status & Buttons -->
                <StackPanel Grid.Row="5" Margin="0,12,0,0">
                    <TextBlock x:Name="sendStatus" Text="" FontSize="12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8" TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite"/>

                    <!-- Connection Details Toggle -->
                    <StackPanel x:Name="sendConnToggle" Orientation="Horizontal" Visibility="Collapsed"
                                Cursor="Hand" Margin="0,0,0,4"
                                MouseLeftButtonDown="SendConnToggle_Click"
                                MouseEnter="DisclosureToggle_MouseEnter" MouseLeave="DisclosureToggle_MouseLeave">
                        <ui:SymbolIcon x:Name="sendConnChevron" Symbol="ChevronRight24" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,4,0" RenderTransformOrigin="0.5,0.5">
                            <ui:SymbolIcon.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </ui:SymbolIcon.RenderTransform>
                        </ui:SymbolIcon>
                        <TextBlock Text="Connection details" FontSize="12"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Connection Details Card -->
                    <Border x:Name="sendConnInfoPanel" Visibility="Collapsed"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                            Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Relay" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="sendRelayText" Grid.Row="0" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Local IP" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="sendLocalIpText" Grid.Row="1" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="sendPublicIpLabel" Grid.Row="2" Grid.Column="0" Text="Public IP" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4" Visibility="Collapsed"/>
                            <TextBlock x:Name="sendPublicIpText" Grid.Row="2" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" Visibility="Collapsed"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Connection" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="sendConnTypeText" Grid.Row="3" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Status" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="sendStatusRowText" Grid.Row="4" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"
                                       TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Security" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock x:Name="sendSecurityText" Grid.Row="5" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="sendBtn" Grid.Column="0"
                                   Appearance="Primary" HorizontalAlignment="Stretch"
                                   Click="Send_Click" IsEnabled="False"
                                   MinHeight="32"
                                   ToolTip="Start sending file (Enter)">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Send24" Margin="0,0,6,0"/>
                                <TextBlock Text="Send" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="sendCancelBtn" Grid.Column="1"
                                   Appearance="Danger" Margin="8,0,0,0"
                                   Click="SendCancel_Click" Visibility="Collapsed"
                                   MinHeight="32"
                                   ToolTip="Cancel transfer (Esc)"
                                   AutomationProperties.Name="Cancel send transfer">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Dismiss24" Margin="0,0,6,0"/>
                                <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                    <Grid x:Name="sendRetryPanel" Visibility="Collapsed" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="sendResumeBtn" Grid.Column="0"
                                   Appearance="Primary" HorizontalAlignment="Stretch"
                                   Click="SendResume_Click"
                                   AutomationProperties.Name="Resume send transfer">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0"/>
                                <TextBlock Text="Resume" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Grid.Column="1" Margin="8,0,0,0" Click="SendStartOver_Click" Content="Start Over"
                                   ToolTip="Discard and start a new transfer"
                                   AutomationProperties.Name="Start over with new transfer"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Receive Panel -->
            <Grid x:Name="recvPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Code Input -->
                <ui:TextBox x:Name="recvCodeBox" Grid.Row="0"
                            PlaceholderText="Enter the transfer code"
                            Icon="{ui:SymbolIcon Key24}"
                            ToolTip="Paste the code from the sender (Ctrl+V)"
                            AutomationProperties.Name="Transfer code"/>
                <TextBlock Grid.Row="1" Text="Codes are single-use and expire when the sender disconnects"
                           FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                           Margin="12,4,0,0"/>

                <!-- Save Location -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="saveFolderBox" Grid.Column="0"
                                PlaceholderText="Save location"
                                LostFocus="SaveFolder_LostFocus"
                                Margin="0,0,6,0"
                                AutomationProperties.Name="Save location folder"/>
                    <ui:Button Grid.Column="1" Click="BrowseFolder_Click"
                               ToolTip="Choose where to save received files"
                               AutomationProperties.Name="Browse save folder">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="FolderOpen24" Margin="0,0,6,0"/>
                            <TextBlock Text="Browse" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </Grid>

                <!-- Empty State Helper -->
                <StackPanel Grid.Row="3" x:Name="recvEmptyState"
                            HorizontalAlignment="Center" Margin="0,48,0,24">
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="36"
                                  Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Enter a code to receive files" HorizontalAlignment="Center"
                               Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="14"/>
                    <TextBlock Text="The sender will give you a code like &quot;1234-apple-banana-cherry&quot;"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Progress -->
                <StackPanel Grid.Row="3" VerticalAlignment="Top" Margin="0,16,0,0"
                            x:Name="recvActivityPanel" Visibility="Collapsed">
                    <StackPanel x:Name="recvProgressPanel" Visibility="Collapsed">
                        <ProgressBar x:Name="recvProgress" IsIndeterminate="True" Minimum="0" Maximum="100"/>
                        <Grid Margin="0,4,0,0">
                            <TextBlock x:Name="recvProgressDetail" Text="" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Left"/>
                            <TextBlock x:Name="recvElapsedText" Text="" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid x:Name="recvSpeedRow" Margin="0,4,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="recvSpeedText" Text="" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Left"/>
                            <TextBlock x:Name="recvEtaText" Text="" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                    <TextBlock x:Name="recvStatus" Text="" FontSize="12" Margin="0,12,0,8"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite"/>

                    <!-- Connection Details Toggle -->
                    <StackPanel x:Name="recvConnToggle" Orientation="Horizontal" Visibility="Collapsed"
                                Cursor="Hand" Margin="0,0,0,4"
                                MouseLeftButtonDown="RecvConnToggle_Click"
                                MouseEnter="DisclosureToggle_MouseEnter" MouseLeave="DisclosureToggle_MouseLeave">
                        <ui:SymbolIcon x:Name="recvConnChevron" Symbol="ChevronRight24" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,4,0" RenderTransformOrigin="0.5,0.5">
                            <ui:SymbolIcon.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </ui:SymbolIcon.RenderTransform>
                        </ui:SymbolIcon>
                        <TextBlock Text="Connection details" FontSize="12"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Connection Details Card -->
                    <Border x:Name="recvConnInfoPanel" Visibility="Collapsed"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                            Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Relay" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="recvRelayText" Grid.Row="0" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Local IP" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="recvLocalIpText" Grid.Row="1" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Connection" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="recvConnTypeText" Grid.Row="2" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Status" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="recvStatusRowText" Grid.Row="3" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"
                                       TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Security" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock x:Name="recvSecurityText" Grid.Row="4" Grid.Column="1" Text="—" FontSize="12"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Received Text Preview -->
                    <Border x:Name="recvTextCard" Visibility="Collapsed"
                            CornerRadius="8" Padding="16" Margin="0,12,0,0"
                            Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" Effect="{StaticResource CardShadow}"
                            MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Received Text" FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                <ui:Button HorizontalAlignment="Right" Appearance="Secondary"
                                           Padding="8,4" Click="CopyReceivedText_Click" ToolTip="Copy to clipboard"
                                           AutomationProperties.Name="Copy received text">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Copy24" FontSize="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Copy" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                            </Grid>
                            <TextBox x:Name="recvTextContent" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MaxHeight="180" VerticalScrollBarVisibility="Auto"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                     FontSize="14"/>
                            <ui:Button x:Name="showFullTextBtn" Visibility="Collapsed"
                                       Appearance="Secondary" Margin="0,8,0,0" Padding="8,4"
                                       Click="ShowFullText_Click"
                                       AutomationProperties.Name="Show full received text">
                                <TextBlock x:Name="showFullTextLabel" Text="Show full text" FontSize="12"/>
                            </ui:Button>
                        </StackPanel>
                    </Border>

                    <!-- Received File Preview -->
                    <Border x:Name="recvFilePreviewCard" Visibility="Collapsed"
                            CornerRadius="8" Padding="16" Margin="0,12,0,0"
                            Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" Effect="{StaticResource CardShadow}"
                            MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                                <ui:SymbolIcon x:Name="recvFileSymbol" Symbol="Document24" FontSize="28"
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                <Image x:Name="recvFileIcon" Width="40" Height="40"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="recvFileName" Text="" FontSize="14" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="recvFileDetail" Text="" FontSize="12" Margin="0,4,0,0"
                                           Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                            <StackPanel x:Name="recvFileActions" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button Click="OpenReceivedFile_Click" ToolTip="Open file"
                                           Appearance="Primary" Padding="8,4" Margin="0,0,4,0"
                                           AutomationProperties.Name="Open received file">
                                    <ui:SymbolIcon Symbol="Open24" FontSize="14"/>
                                </ui:Button>
                                <ui:Button Click="OpenFolder_Click" ToolTip="Open in folder"
                                           Appearance="Secondary" Padding="8,4" Margin="0,0,4,0"
                                           AutomationProperties.Name="Open containing folder">
                                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
                                </ui:Button>
                                <ui:Button Click="CopyReceivedFilePath_Click" ToolTip="Copy file path"
                                           Appearance="Secondary" Padding="8,4"
                                           AutomationProperties.Name="Copy file path">
                                    <ui:SymbolIcon Symbol="Copy24" FontSize="14"/>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel><!-- end recvActivityPanel -->

                <!-- Receive Button -->
                <StackPanel Grid.Row="4" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="recvBtn" Grid.Column="0"
                                   Appearance="Primary" HorizontalAlignment="Stretch"
                                   Click="Recv_Click"
                                   MinHeight="32"
                                   ToolTip="Start receiving file (Enter)">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,6,0"/>
                                <TextBlock Text="Receive" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="recvCancelBtn" Grid.Column="1"
                                   Appearance="Danger" Margin="8,0,0,0"
                                   Click="RecvCancel_Click" Visibility="Collapsed"
                                   MinHeight="32"
                                   ToolTip="Cancel transfer (Esc)"
                                   AutomationProperties.Name="Cancel receive transfer">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Dismiss24" Margin="0,0,6,0"/>
                                <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                    <Grid x:Name="recvRetryPanel" Visibility="Collapsed" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="recvResumeBtn" Grid.Column="0"
                                   Appearance="Primary" HorizontalAlignment="Stretch"
                                   Click="RecvResume_Click"
                                   AutomationProperties.Name="Resume receive transfer">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0"/>
                                <TextBlock Text="Resume" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Grid.Column="1" Margin="8,0,0,0" Click="RecvStartOver_Click" Content="Start Over"
                                   ToolTip="Discard and start a new transfer"
                                   AutomationProperties.Name="Start over with new receive"/>
                    </Grid>
                </StackPanel>
            </Grid>
            </Grid>
            </ScrollViewer>

            <!-- History Panel (overlay) -->
            <Border x:Name="historyPanel" Grid.Row="1" Grid.RowSpan="3" Visibility="Collapsed"
                    CornerRadius="8" Padding="16" Margin="-1"
                    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" Panel.ZIndex="100"
                    Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Transfer History" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        <ui:Button HorizontalAlignment="Right" Appearance="Secondary"
                                   Padding="8,4" Click="CloseHistory_Click" ToolTip="Close"
                                   AutomationProperties.Name="Close history panel">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                        </ui:Button>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ui:TextBox x:Name="historySearchBox" Grid.Row="0"
                                    PlaceholderText="Search history..."
                                    Margin="0,0,0,12"
                                    TextChanged="HistorySearch_TextChanged"
                                    AutomationProperties.Name="Search transfer history"/>
                        <ItemsControl x:Name="historyList" Grid.Row="1"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                    </ItemsControl>
                    <TextBlock x:Name="historyEmpty" Grid.Row="1" Text="No transfers yet"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                               FontSize="14"/>
                    </Grid>
                    <ui:Button Grid.Row="2" Content="Clear History" Margin="0,12,0,0"
                               Appearance="Secondary" HorizontalAlignment="Left"
                               Click="ClearHistory_Click" x:Name="clearHistoryBtn"
                               ToolTip="Delete all transfer history"/>
                </Grid>
            </Border>

            <!-- Settings Panel (overlay) -->
            <Border x:Name="settingsPanel" Grid.Row="1" Grid.RowSpan="3" Visibility="Collapsed"
                    CornerRadius="8" Padding="16,16,8,16" Margin="-1"
                    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" Panel.ZIndex="100"
                    Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        <ui:Button HorizontalAlignment="Right" Appearance="Secondary"
                                   Padding="8,4" Click="CloseSettings_Click" ToolTip="Close"
                                   AutomationProperties.Name="Close settings panel">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                        </ui:Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                        <StackPanel Margin="0,0,4,0">

                            <!-- ── Speed ── -->
                            <TextBlock Text="Speed" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Upload Speed Limit" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="throttleCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="Throttle_Changed"
                                      AutomationProperties.Name="Upload speed limit">
                                <ComboBoxItem Content="Unlimited" Tag=""/>
                                <ComboBoxItem Content="500 KB/s" Tag="500k"/>
                                <ComboBoxItem Content="1 MB/s" Tag="1M"/>
                                <ComboBoxItem Content="5 MB/s" Tag="5M"/>
                                <ComboBoxItem Content="10 MB/s" Tag="10M"/>
                            </ComboBox>

                            <!-- section divider -->
                            <Rectangle Height="1" Margin="0,20,0,16"
                                       Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Opacity="0.6"/>

                            <!-- ── Network ── -->
                            <TextBlock Text="Network" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Relay Server" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                            <ui:TextBox x:Name="relayBox" PlaceholderText="Default (public relay)"
                                        LostFocus="Relay_LostFocus"
                                        AutomationProperties.Name="Relay server address"/>
                            <TextBlock Text="Use your own relay for faster transfers"
                                       FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="Fallback Relay Server" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,16,0,8"/>
                            <ui:TextBox x:Name="fallbackRelayBox" PlaceholderText="Used automatically if primary relay fails"
                                        LostFocus="FallbackRelay_LostFocus"
                                        AutomationProperties.Name="Fallback relay server address"/>
                            <TextBlock Text="Tried when primary relay is unreachable or times out"
                                       FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="SOCKS5 Proxy" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,16,0,8"/>
                            <ui:TextBox x:Name="socks5Box" PlaceholderText="e.g. 127.0.0.1:9050 (Tor)"
                                        LostFocus="Socks5_LostFocus"
                                        AutomationProperties.Name="SOCKS5 proxy address"/>
                            <TextBlock Text="Requires Tor running separately on your machine"
                                       FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0"/>

                            <!-- section divider -->
                            <Rectangle Height="1" Margin="0,20,0,16"
                                       Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Opacity="0.6"/>

                            <!-- ── Transfer ── -->
                            <TextBlock Text="Transfer" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Disable Compression" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Disables croc's transfer compression (smart zip compression still applies)"
                                               FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="noCompressCheck" Grid.Column="1" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Checked="NoCompress_Changed" Unchecked="NoCompress_Changed"
                                                 AutomationProperties.Name="Disable compression"/>
                            </Grid>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Force Local Transfer" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Bypass relay — LAN only, full local speed (both devices must be on same network)"
                                               FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="forceLocalCheck" Grid.Column="1" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Checked="ForceLocal_Changed" Unchecked="ForceLocal_Changed"
                                                 AutomationProperties.Name="Force local transfer"/>
                            </Grid>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Overwrite Existing Files" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Off = auto-rename incoming files instead of replacing"
                                               FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="overwriteCheck" Grid.Column="1" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Checked="Overwrite_Changed" Unchecked="Overwrite_Changed"
                                                 AutomationProperties.Name="Overwrite existing files"/>
                            </Grid>

                            <!-- section divider -->
                            <Rectangle Height="1" Margin="0,20,0,16"
                                       Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Opacity="0.6"/>

                            <!-- ── Security ── -->
                            <TextBlock Text="Security" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Encryption Curve" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="curveCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="Curve_Changed" Margin="0,0,0,0"
                                      AutomationProperties.Name="Encryption curve">
                                <ComboBoxItem Content="P-256 (default)" Tag="p256"/>
                                <ComboBoxItem Content="P-521 (strongest)" Tag="p521"/>
                                <ComboBoxItem Content="P-384" Tag="p384"/>
                                <ComboBoxItem Content="SIEC" Tag="siec"/>
                            </ComboBox>
                            <TextBlock x:Name="curveDescription"
                                       Text="Fast, widely trusted — standard for TLS and most apps"
                                       FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="Hash Algorithm" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,16,0,8"/>
                            <ComboBox x:Name="hashCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="Hash_Changed" Margin="0,0,0,0"
                                      AutomationProperties.Name="Hash algorithm">
                                <ComboBoxItem Content="xxhash (default, fastest)" Tag="xxhash"/>
                                <ComboBoxItem Content="imohash (fast, file-level)" Tag="imohash"/>
                                <ComboBoxItem Content="MD5" Tag="md5"/>
                            </ComboBox>
                            <TextBlock x:Name="hashDescription"
                                       Text="Non-cryptographic, extremely fast — best for transfer verification"
                                       FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <TextBlock Text="Passphrase" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,16,0,8"/>
                            <ui:TextBox x:Name="passphraseBox" PlaceholderText="Optional shared secret"
                                        LostFocus="Passphrase_LostFocus"
                                        AutomationProperties.Name="Transfer passphrase"/>
                            <TextBlock Text="Both sender and receiver must use the same passphrase"
                                       FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0"/>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Antivirus Scan" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Scan received files with Windows Defender"
                                               FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="avScanCheck" Grid.Column="1" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Checked="AvScan_Changed" Unchecked="AvScan_Changed"
                                                 AutomationProperties.Name="Antivirus scan"/>
                            </Grid>

                            <!-- section divider -->
                            <Rectangle Height="1" Margin="0,20,0,16"
                                       Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Opacity="0.6"/>

                            <!-- Reset -->
                            <ui:Button Content="Reset to defaults" Margin="0,0,0,4"
                                       Appearance="Secondary" HorizontalAlignment="Left"
                                       Click="ResetSettings_Click"
                                       ToolTip="Restore all settings to their default values"
                                       AutomationProperties.Name="Reset all settings to defaults"/>

                            <!-- section divider -->
                            <Rectangle Height="1" Margin="0,20,0,16"
                                       Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Opacity="0.6"/>

                            <!-- ── Data ── -->
                            <TextBlock Text="Data" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,8"/>

                            <!-- Storage footprint card -->
                            <Border CornerRadius="6" Padding="12,12" Margin="0,0,0,16"
                                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Storage used" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="storageDetailText" Text="Calculating..."
                                                   FontSize="12" Margin="0,4,0,0"
                                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock x:Name="storageTotalText" Grid.Column="1" Text="..."
                                               FontSize="20" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                </Grid>
                            </Border>

                            <!-- Clean on exit toggle -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Clear Settings on Exit" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Removes settings, history, and logs when VIA closes. The transfer engine is always kept."
                                               FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="cleanOnExitCheck" Grid.Column="1" HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Checked="CleanOnExit_Changed" Unchecked="CleanOnExit_Changed"
                                                 AutomationProperties.Name="Delete app data on exit"/>
                            </Grid>

                            <ui:Button Content="Clear app data now" Margin="0,0,0,4"
                                       Appearance="Danger" HorizontalAlignment="Left"
                                       Click="ClearAppData_Click"
                                       ToolTip="Delete settings, history, logs, and cached files"
                                       AutomationProperties.Name="Delete all app data"/>
                            <TextBlock Text="Resets settings, history, logs, and cached files"
                                       FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>

                            <!-- section divider -->
                            <Rectangle Height="1" Margin="0,20,0,16"
                                       Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Opacity="0.6"/>

                            <!-- ── About ── -->
                            <TextBlock Text="About" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,12"/>

                            <!-- App identity card -->
                            <Border CornerRadius="6" Padding="12,12" Margin="0,0,0,16"
                                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Source="/via_logo.png" Width="40" Height="40"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="VIA x4" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="aboutVersion" FontSize="12"
                                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                                   Margin="0,4,0,0"/>
                                        <TextBlock Text="Copyright &#169; 2026 VIA" FontSize="12"
                                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Description -->
                            <TextBlock FontSize="12" Margin="0,0,0,16"
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap">
                                VIA x4 (Transfer) is a secure, end-to-end encrypted file transfer app.
                                Send any file to any device over the internet or your local network
                                &#8212; no cloud, no accounts, nothing stored.
                            </TextBlock>

                            <!-- Quick-action buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <ui:Button Content="Open log folder" Appearance="Secondary"
                                           Margin="0,0,6,0"
                                           Click="OpenLogFolder_Click"
                                           AutomationProperties.Name="Open VIA x4 log folder"/>
                                <ui:Button Content="Copy diagnostics" Appearance="Secondary"
                                           Click="CopyDiagnostics_Click"
                                           AutomationProperties.Name="Copy diagnostic info to clipboard"/>
                            </StackPanel>

                            <!-- Engine attribution -->
                            <TextBlock FontSize="12" Margin="0,0,0,4"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       TextWrapping="Wrap">
                                Powered by
                                <Run FontWeight="SemiBold">croc</Run>
                                (github.com/schollz/croc) &#8212; MIT License.
                                Transfers are encrypted with PAKE and ECDH using croc&#39;s relay network.
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Version -->
            <TextBlock x:Name="versionText" Grid.Row="3" FontSize="10"
                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
